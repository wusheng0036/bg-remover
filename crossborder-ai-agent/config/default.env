# 跨境电商 AI 运营助手 - 环境配置
# 复制此文件为 .env 并填入真实值

# ============ OpenClaw 配置 ============
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_API_KEY=your_openclaw_api_key

# ============ 飞书配置 ============
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxx

# ============ AI 模型配置 ============
# 推荐使用国产模型，成本低、速度快
AI_MODEL=deepseek  # deepseek / kimi / qwen / gpt4
DEEPSEEK_API_KEY=sk_xxxxxxxxxxxxx
KIMI_API_KEY=sk_xxxxxxxxxxxxx
QWEN_API_KEY=sk_xxxxxxxxxxxxx
OPENAI_API_KEY=sk_xxxxxxxxxxxxx  # 可选

# ============ 数据库配置 ============
DATABASE_PATH=./data/agents.db
USE_FEISHU_BITABLE=true  # 是否使用飞书多维表格存储
FEISHU_BITABLE_TOKEN=xxxxx  # 飞书表格 token

# ============ 业务配置 ============
DEFAULT_CURRENCY=CNY  # CNY / USD
TIMEZONE=Asia/Shanghai
LOG_LEVEL=info  # debug / info / warn / error

# ============ 通知配置 ============
NOTIFY_EMAIL=  # 可选，告警邮件
NOTIFY_FEISHU_USER=ou_xxxxxxxxxxxxx  # 可选，告警通知飞书用户
