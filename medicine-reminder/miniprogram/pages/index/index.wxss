/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.streak {
  font-size: 26rpx;
  color: #07C160;
  margin-top: 10rpx;
}

.progress-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 16rpx;
  background: #e5e5e5;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #10B981);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-percent {
  text-align: right;
  font-size: 24rpx;
  color: #07C160;
  margin-top: 8rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.medicine-card {
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.medicine-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.medicine-time {
  font-size: 24rpx;
  color: #999;
}

.medicine-time.overdue {
  color: #FF3B30;
}

.medicine-time.current {
  color: #07C160;
}

.card-body {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.time {
  color: #07C160;
}

.card-footer {
  text-align: right;
}

.checkin-btn {
  display: inline-block;
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  border: 2rpx solid #07C160;
  background: #fff;
  color: #07C160;
}

.checkin-btn.active {
  background: #07C160;
  color: #fff;
}

.completed-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #666;
}

.completed-item:last-child {
  border-bottom: none;
}

.completed-time {
  color: #999;
}

.checkmark {
  color: #07C160;
}

.add-temp {
  text-align: center;
  padding: 30rpx;
  color: #07C160;
  font-size: 28rpx;
  border: 2rpx dashed #07C160;
  border-radius: 12rpx;
  margin-top: 20rpx;
}
