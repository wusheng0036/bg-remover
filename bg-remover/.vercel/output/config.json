{
  "version": 3,
  "routes": [
    {
      "src": "/_next/__private/trace",
      "dest": "/404",
      "status": 404,
      "continue": true
    },
    {
      "src": "/404/?",
      "status": 404,
      "continue": true
    },
    {
      "src": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/_next/data/(.*)",
      "dest": "/_next/data/$1",
      "check": true
    },
    {
      "src": "/_next/data/(.*)",
      "status": 404
    },
    {
      "handle": "resource"
    },
    {
      "src": "/.*",
      "status": 404
    },
    {
      "handle": "miss"
    },
    {
      "src": "/_next/static/.+",
      "status": 404,
      "check": true,
      "dest": "/_next/static/not-found.txt",
      "headers": {
        "content-type": "text/plain; charset=utf-8"
      }
    },
    {
      "handle": "hit"
    },
    {
      "src": "/_next/static/(?:[^/]+/pages|pages|chunks|runtime|css|image|media|8b9nLoRn3AYqzmqnksIiD)/.+",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true,
      "important": true
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": ".*",
      "dest": "/404"
    }
  ],
  "overrides": {
    "404.html": {
      "path": "404",
      "contentType": "text/html; charset=utf-8"
    },
    "dashboard.html": {
      "path": "dashboard",
      "contentType": "text/html; charset=utf-8"
    },
    "faq.html": {
      "path": "faq",
      "contentType": "text/html; charset=utf-8"
    },
    "index.html": {
      "path": "index",
      "contentType": "text/html; charset=utf-8"
    },
    "preview-test.html": {
      "path": "preview-test",
      "contentType": "text/html; charset=utf-8"
    },
    "pricing.html": {
      "path": "pricing",
      "contentType": "text/html; charset=utf-8"
    }
  },
  "framework": {
    "version": "14.1.0"
  },
  "crons": []
}
